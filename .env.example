# GB Coder Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED: AI Features
# ============================================

# Google Gemini API Key (Required for AI Chat Assistant)
# Get your key from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# OPTIONAL: Feature Flags
# ============================================

# Enable/Disable AI suggestions
VITE_ENABLE_AI_SUGGESTIONS=true

# Enable/Disable external libraries manager
VITE_ENABLE_EXTERNAL_LIBRARIES=true

# ============================================
# OPTIONAL: Development
# ============================================

# Custom development port (default: 5173)
VITE_DEV_PORT=5173

# ============================================
# OPTIONAL: Analytics
# ============================================

# Google Analytics 4 Measurement ID
VITE_GA4_MEASUREMENT_ID=

# Vercel Analytics ID
VITE_VERCEL_ANALYTICS_ID=

# ============================================
# NOTES:
# ============================================
# - Never commit .env file with real values
# - .env is already in .gitignore
# - Only VITE_* variables are exposed to client
# - Restart dev server after changing .env
