{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/ai.js": {
      "maxDuration": 120
    }
  },
  "rewrites": [
    { "source": "/api/ai", "destination": "/api/ai" },
    { "source": "/api/health", "destination": "/api/health" },
    { "source": "/api/share", "destination": "/api/share" },
    { "source": "/api/preview", "destination": "/api/preview" },
    { "source": "/preview/(.*)", "destination": "/index.html" }
  ]
}
