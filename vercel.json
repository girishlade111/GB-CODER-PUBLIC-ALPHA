{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/ai.js": {
      "maxDuration": 120
    }
  },
  "rewrites": [
    { "source": "/api/ai", "destination": "/api/ai" },
    { "source": "/api/health", "destination": "/api/health" }
  ]
}
